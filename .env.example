# Claude Usage Dashboard — Configuration
# Copy this file to .env and adjust as needed

# Port for the Python backend API server
BACKEND_PORT=9001

# Port for the Vite dev server (non-Docker only)
FRONTEND_PORT=5173

# Path to your Claude Code data directory
# Default: ~/.claude (auto-detected if not set)
# In Docker: set to the container mount path, e.g. /claude-data
CLAUDE_DATA_DIR=~/.claude
